    "contact": {
      "keywords": ["联系", "电话", "微信", "地址"],
      "reply": "联系方式：\n📞 电话：400-XXX-XXXX\n📧 邮箱：contact@company.com\n📍 地址：北京市朝阳区 XXX 路 XXX 号",
      "priority": 2
    },
    "workingHours": {
      "keywords": ["时间", "营业", "上班", "下班"],
